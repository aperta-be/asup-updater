# General APERTA variables
SELF_TEST=1
DRY_RUN=1
VERBOSE=1

# ASUP variable
COMPOSER_UPDATE_CONSTRAINTS=1
APP_PUBLIC_ROOT_DIRECTORY=web
MATTERMOST_HOOK="https://your-mattermost-instance/hooks/your-webhook-id"

# Repository variables
VCS_PROVIDER="gitlab"  # Options: gitlab, github
GIT_AUTO_MERGE=1
GIT_HOST="gitlab.example.com"  # Your GitLab/GitHub instance URL
GIT_NAMESPACE="your-namespace"
GIT_PROJECT="your-project"
GIT_BRANCH_TARGET="main"  # Target branch for updates (e.g., main, master, develop)
GIT_CLONE_URL="git@gitlab.example.com:your-namespace/your-project.git"

# Credentials - DO NOT commit actual credentials!
GIT_APERTA_USER="your-username"
GIT_APERTA_TOKEN="your-access-token"

# SSH keys - DO NOT commit actual keys!
# Generate your own SSH keys and add them to your Git provider
# SSH_PUBLIC_KEY="your-public-key-content"
# SSH_PRIVATE_KEY="your-private-key-content"