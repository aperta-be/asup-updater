<?xml version="1.0"?>
<ruleset name="ASUP Coding Standard">
    <description>ASUP coding standard based on PSR-12</description>

    <!-- Paths to check -->
    <file>scripts/app/php</file>

    <!-- Exclude paths -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <!-- Use PSR-12 as base -->
    <rule ref="PSR12"/>

    <!-- Show progress -->
    <arg value="p"/>
    <arg name="colors"/>

    <!-- Show sniff codes in all reports -->
    <arg value="s"/>

    <!-- Use tabs -->
    <arg name="tab-width" value="4"/>

    <!-- Enforce UTF-8 -->
    <arg name="encoding" value="utf-8"/>

    <!-- Custom rules -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="120"/>
        </properties>
    </rule>

    <!-- Enforce PHP 7.4+ syntax -->
    <config name="php_version" value="70400"/>

    <!-- Enforce strict types declaration -->
    <rule ref="Generic.PHP.RequireStrictTypes"/>

    <!-- Enforce camelCase method names -->
    <rule ref="PSR1.Methods.CamelCapsMethodName"/>

    <!-- Disallow some functions -->
    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="var_dump" value="null"/>
                <element key="print_r" value="null"/>
                <element key="die" value="null"/>
                <element key="exit" value="null"/>
            </property>
        </properties>
    </rule>
</ruleset>