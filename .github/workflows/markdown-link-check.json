{
  "ignorePatterns": [
    {
      "pattern": "^https://aperta-be.github.io"
    },
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^https://github.com/aperta-be"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/docs/",
      "replacement": "{{BASEURL}}/docs/"
    }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com/"],
      "headers": {
        "Accept": "application/vnd.github.v3+json"
      }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 429]
}